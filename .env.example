# Copy to .env.local for local dev, and set the RUNTIME vars in your host
# (e.g. Vercel → Project → Settings → Environment Variables) for deploys.
# .env.local is gitignored and is NOT deployed, so the host needs these set
# explicitly or every DB route returns 503.

# ---- Runtime (required by the deployed app) ----
# Neon POOLED connection string, pointing at the dedicated `nibbsreport` database
# (NOT nexemz's `neondb`). Missing/wrong value => 503 on every DB route.
DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxx-pooler.REGION.aws.neon.tech/nibbsreport?channel_binding=require&sslmode=require"

# Set true in production (HTTPS) so the session cookie carries the Secure flag.
SESSION_COOKIE_SECURE=true

# ---- Runtime (optional: enables outbound email) ----
# Gmail SMTP App Password auth. If unset, credential/reset emails are skipped
# (no crash, no 503) — but "create analyst" and "forgot password" won't email.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword

# ---- Scripts only (NOT needed on the host) ----
# Used by scripts/db-create.mjs to create the `nibbsreport` database.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"
# Used by scripts/seed-admin.mjs to create/reset the first admin.
ADMIN_EMAIL=admin@example.com
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
# Base URL for links in seeded-admin emails (defaults to http://localhost:3000).
APP_URL=https://your-app.vercel.app
